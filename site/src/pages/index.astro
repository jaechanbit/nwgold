---
import { Image } from "astro:assets";
import Layout from "../layouts/Layout.astro";
import heroImage from "../assets/hero-repair.png";
import repairBefore from "../assets/repair-before.png";
import repairAfter from "../assets/repair-after.png";
import workshopImage from "../assets/workshop.png";
import goldBuyingImage from "../assets/gold-buying.png";
import {
  products,
  isPriceFresh,
  formatPrice,
  formatCheckedAt,
} from "../data/products";

const visibleProducts = products.filter((product) => isPriceFresh(product.priceCheckedAt));
const mapQuery = encodeURIComponent("전북 남원시 의총로 100 남원금방");
---

<Layout
  title="남원금방 | 귀금속 판매·수리·금 매입"
  description="남원에서 20년 이상의 경험으로 반지, 목걸이, 예물, 순금, 금 매입과 귀금속 수리를 친절하게 상담합니다."
>
  <header class="site-header" data-header>
    <a class="brand" href="#top" aria-label="남원금방 처음으로">
      <strong>남원금방</strong>
      <span>20년 이상의 경험</span>
    </a>
    <button class="menu-button" type="button" aria-expanded="false" aria-controls="main-menu">
      <i class="ph ph-list" aria-hidden="true"></i>
      <span class="sr-only">메뉴 열기</span>
    </button>
    <nav id="main-menu" class="main-nav" aria-label="주요 메뉴">
      <a href="#repair">수리 안내</a>
      <a href="#gold-buying">금 매입</a>
      <a href="#products">상품</a>
      <a href="#visit">매장 안내</a>
    </nav>
    <a class="header-phone" href="tel:0636269060">
      <i class="ph ph-phone" aria-hidden="true"></i>
      063-626-9060
    </a>
  </header>

  <main id="top">
    <section class="hero section-shell" aria-labelledby="hero-title">
      <div class="hero-copy">
        <p class="eyebrow">전북 남원 · 20년 이상의 현장 경험</p>
        <h1 id="hero-title">오래 아끼는<br />마음까지 고칩니다</h1>
        <p class="hero-description">
          오래 착용한 반지와 목걸이도 다시 빛날 수 있도록.<br />필요한 만큼 정확히 살피고 친절하게 안내합니다.
        </p>
        <div class="hero-actions">
          <a class="button button-primary" href="tel:0636269060">
            <i class="ph ph-phone" aria-hidden="true"></i>
            수리 가능 여부 전화로 물어보기
          </a>
          <a class="text-link" href="#visit">
            매장 위치 확인
            <i class="ph ph-arrow-down" aria-hidden="true"></i>
          </a>
        </div>
        <dl class="hero-hours">
          <div><dt>영업시간</dt><dd>월~토 10:00~18:00</dd></div>
          <div><dt>정기휴무</dt><dd>매주 일요일</dd></div>
        </dl>
      </div>
      <div class="hero-visual">
        <Image src={heroImage} alt="귀금속 반지를 정교하게 수리하는 손" widths={[640, 960, 1280]} sizes="(max-width: 800px) 100vw, 52vw" loading="eager" />
        <span class="temporary-badge">연출 이미지</span>
      </div>
    </section>

    <section class="trust-band" aria-label="남원금방의 약속">
      <div class="trust-lead">
        <strong>20년 이상의<br />현장 경험</strong>
      </div>
      <article>
        <i class="ph ph-hand-heart" aria-hidden="true"></i>
        <div><h2>친절한 상담</h2><p>상태를 먼저 살피고 필요한 작업만 안내합니다.</p></div>
      </article>
      <article>
        <i class="ph ph-wrench" aria-hidden="true"></i>
        <div><h2>숙련된 수리</h2><p>세공부터 세척까지 오래 사용할 수 있도록 돕습니다.</p></div>
      </article>
      <article>
        <i class="ph ph-diamond" aria-hidden="true"></i>
        <div><h2>투명한 가격</h2><p>상품 가격과 최종 확인일을 함께 공개합니다.</p></div>
      </article>
    </section>

    <section id="repair" class="repair section-shell section-pad" aria-labelledby="repair-title">
      <div class="section-heading">
        <p class="eyebrow">새것처럼, 더 안전하게</p>
        <h2 id="repair-title">주얼리 수리 서비스</h2>
        <p>끊어진 체인, 얇아진 링, 헐거운 세팅까지 상태를 세심하게 점검합니다.</p>
      </div>
      <div class="repair-grid">
        <div class="repair-list">
          <ul>
            <li><i class="ph ph-check" aria-hidden="true"></i> 반지 사이즈 조절</li>
            <li><i class="ph ph-check" aria-hidden="true"></i> 체인 및 잠금장치 수리</li>
            <li><i class="ph ph-check" aria-hidden="true"></i> 보석 세팅과 보강</li>
            <li><i class="ph ph-check" aria-hidden="true"></i> 광택, 세척, 상태 점검</li>
          </ul>
          <a class="button button-outline" href="tel:0636269060">수리 상담 전화하기</a>
        </div>
        <div class="before-after" aria-label="수리 전후 예시 이미지">
          <figure><span>Before</span><Image src={repairBefore} alt="수리 전 마모된 반지 연출 이미지" width={520} /></figure>
          <i class="ph ph-arrow-right" aria-hidden="true"></i>
          <figure><span>After</span><Image src={repairAfter} alt="수리 후 정돈된 반지 연출 이미지" width={520} /></figure>
        </div>
        <figure class="workshop-photo">
          <Image src={workshopImage} alt="귀금속 수리 도구가 놓인 작업대 연출 이미지" widths={[520, 800]} sizes="(max-width: 800px) 100vw, 33vw" />
          <figcaption>사진은 화면 구성을 위한 연출 이미지입니다.</figcaption>
        </figure>
      </div>
    </section>

    <section id="gold-buying" class="gold-buying" aria-labelledby="gold-title">
      <div class="gold-photo">
        <Image src={goldBuyingImage} alt="감정을 기다리는 여러 귀금속 연출 이미지" widths={[640, 960, 1280]} sizes="(max-width: 800px) 100vw, 50vw" />
        <span class="temporary-badge">연출 이미지</span>
      </div>
      <div class="gold-copy">
        <p class="eyebrow">안심하고 거래하실 수 있도록</p>
        <h2 id="gold-title">금 매입 안내</h2>
        <p>당일 시세와 품위, 중량을 확인한 뒤 기준을 차근차근 설명해 드립니다.</p>
        <ol class="gold-steps">
          <li><i class="ph ph-scales" aria-hidden="true"></i><span><strong>정확한 감정</strong>품위와 중량 확인</span></li>
          <li><i class="ph ph-chart-line-up" aria-hidden="true"></i><span><strong>당일 시세</strong>기준을 투명하게 안내</span></li>
          <li><i class="ph ph-money" aria-hidden="true"></i><span><strong>현금 지급</strong>확인 후 즉시 안내</span></li>
        </ol>
        <a class="button button-outline" href="tel:0636269060">금 매입 상담하기</a>
      </div>
    </section>

    <section id="products" class="products section-shell section-pad" aria-labelledby="products-title">
      <div class="products-heading">
        <div>
          <p class="eyebrow">믿을 수 있는 품질, 투명한 가격</p>
          <h2 id="products-title">주요 상품 안내</h2>
        </div>
        <p class="sample-notice"><i class="ph ph-info" aria-hidden="true"></i> 상품과 가격은 화면 구성을 위한 예시입니다.</p>
      </div>
      <div class="filter-list" role="group" aria-label="상품 분류">
        <button class="filter-button is-active" type="button" data-filter="전체" aria-pressed="true">전체</button>
        {(["반지", "목걸이", "예물", "순금"] as const).map((category) => (
          <button class="filter-button" type="button" data-filter={category} aria-pressed="false">{category}</button>
        ))}
      </div>
      <div class="product-grid" aria-live="polite">
        {visibleProducts.map((product) => (
          <article class="product-card" data-category={product.category}>
            <button
              class="product-open"
              type="button"
              data-name={product.name}
              data-description={product.description}
              data-material={product.material}
              data-price={formatPrice(product.price)}
              data-checked={formatCheckedAt(product.priceCheckedAt)}
              aria-label={`${product.name} 상세 보기`}
            >
              <Image src={product.image} alt={`${product.name} 연출 이미지`} width={520} />
              <span class="product-category">{product.category}</span>
              <span class="product-name">{product.name}</span>
              <span class="product-material">{product.material}</span>
              <strong>{formatPrice(product.price)}</strong>
              <small>가격 확인 {formatCheckedAt(product.priceCheckedAt)}</small>
            </button>
          </article>
        ))}
      </div>
    </section>

    <section class="consultation section-shell section-pad" aria-labelledby="consultation-title">
      <div class="section-heading inline-heading">
        <p class="eyebrow">처음 방문하셔도 편안하게</p>
        <h2 id="consultation-title">방문 상담, 이렇게 진행합니다</h2>
      </div>
      <ol class="consultation-steps">
        <li><span>01</span><i class="ph ph-phone" aria-hidden="true"></i><div><strong>전화 문의</strong><p>궁금한 상품과 수리를 먼저 알려주세요.</p></div></li>
        <li><span>02</span><i class="ph ph-magnifying-glass" aria-hidden="true"></i><div><strong>제품 점검</strong><p>방문 후 상태와 요청을 함께 확인합니다.</p></div></li>
        <li><span>03</span><i class="ph ph-wrench" aria-hidden="true"></i><div><strong>작업 안내</strong><p>비용과 소요 시간을 설명해 드립니다.</p></div></li>
        <li><span>04</span><i class="ph ph-check-circle" aria-hidden="true"></i><div><strong>결과 확인</strong><p>완성 상태와 관리 방법을 안내합니다.</p></div></li>
      </ol>
    </section>

    <section id="visit" class="visit section-shell" aria-labelledby="visit-title">
      <div class="visit-copy">
        <p class="eyebrow">남원금방 찾아오시는 길</p>
        <h2 id="visit-title">가까이에서<br />친절하게 상담합니다</h2>
        <address>
          <p><i class="ph ph-map-pin" aria-hidden="true"></i> 전북 남원시 의총로 100</p>
          <p><i class="ph ph-phone" aria-hidden="true"></i> <a href="tel:0636269060">063-626-9060</a></p>
          <p><i class="ph ph-clock" aria-hidden="true"></i> 월~토 10:00~18:00</p>
          <p><i class="ph ph-calendar-x" aria-hidden="true"></i> 매주 일요일 휴무</p>
        </address>
        <div class="visit-actions">
          <a class="button button-primary" href={`https://map.naver.com/p/search/${mapQuery}`} target="_blank" rel="noreferrer">
            <i class="ph ph-navigation-arrow" aria-hidden="true"></i> 네이버 지도에서 길찾기
          </a>
          <a class="text-link" href="tel:0636269060">전화로 문의하기</a>
        </div>
      </div>
      <a
        class="map-panel"
        href={`https://map.naver.com/p/search/${mapQuery}`}
        target="_blank"
        rel="noreferrer"
        aria-label="네이버 지도에서 남원금방 위치 확인"
      >
        <i class="ph ph-map-pin-area" aria-hidden="true"></i>
        <span>전북 남원시 의총로 100</span>
        <strong>네이버 지도에서 위치 확인</strong>
        <small>새 창에서 정확한 위치와 길찾기를 확인합니다.</small>
      </a>
    </section>
  </main>

  <footer class="site-footer">
    <div><strong>남원금방</strong><p>20년 이상의 경험으로 정성껏 상담합니다.</p></div>
    <div><p>전북 남원시 의총로 100</p><p>063-626-9060 · 월~토 10:00~18:00</p></div>
    <p>실제 상품 사진과 가격은 공개 전 점주 확인이 필요합니다.</p>
  </footer>

  <div class="mobile-cta" aria-label="빠른 문의">
    <a href={`https://map.naver.com/p/search/${mapQuery}`} target="_blank" rel="noreferrer"><i class="ph ph-map-pin" aria-hidden="true"></i> 길찾기</a>
    <a href="tel:0636269060"><i class="ph ph-phone" aria-hidden="true"></i> 전화 문의</a>
  </div>

  <dialog class="product-dialog" data-product-dialog>
    <button class="dialog-close" type="button" data-dialog-close aria-label="상품 상세 닫기"><i class="ph ph-x" aria-hidden="true"></i></button>
    <p class="eyebrow">상품 상세 안내</p>
    <h2 data-dialog-name></h2>
    <p class="dialog-material" data-dialog-material></p>
    <p data-dialog-description></p>
    <div class="dialog-price"><strong data-dialog-price></strong><small data-dialog-checked></small></div>
    <a class="button button-primary" href="tel:0636269060"><i class="ph ph-phone" aria-hidden="true"></i> 전화로 재고 문의</a>
  </dialog>

  <script>
    const menuButton = document.querySelector<HTMLButtonElement>(".menu-button");
    const menu = document.querySelector<HTMLElement>(".main-nav");
    menuButton?.addEventListener("click", () => {
      const expanded = menuButton.getAttribute("aria-expanded") === "true";
      menuButton.setAttribute("aria-expanded", String(!expanded));
      menu?.classList.toggle("is-open", !expanded);
    });
    menu?.querySelectorAll("a").forEach((link) => link.addEventListener("click", () => {
      menuButton?.setAttribute("aria-expanded", "false");
      menu?.classList.remove("is-open");
    }));

    const filters = document.querySelectorAll<HTMLButtonElement>(".filter-button");
    const cards = document.querySelectorAll<HTMLElement>(".product-card");
    filters.forEach((button) => button.addEventListener("click", () => {
      const selected = button.dataset.filter;
      filters.forEach((item) => {
        const active = item === button;
        item.classList.toggle("is-active", active);
        item.setAttribute("aria-pressed", String(active));
      });
      cards.forEach((card) => {
        card.hidden = selected !== "전체" && card.dataset.category !== selected;
      });
    }));

    const dialog = document.querySelector<HTMLDialogElement>("[data-product-dialog]");
    document.querySelectorAll<HTMLButtonElement>(".product-open").forEach((button) => {
      button.addEventListener("click", () => {
        const set = (selector: string, value = "") => {
          const target = dialog?.querySelector<HTMLElement>(selector);
          if (target) target.textContent = value;
        };
        set("[data-dialog-name]", button.dataset.name);
        set("[data-dialog-material]", button.dataset.material);
        set("[data-dialog-description]", button.dataset.description);
        set("[data-dialog-price]", button.dataset.price);
        set("[data-dialog-checked]", `가격 확인 ${button.dataset.checked}`);
        dialog?.showModal();
      });
    });
    dialog?.querySelector("[data-dialog-close]")?.addEventListener("click", () => dialog.close());
    dialog?.addEventListener("click", (event) => {
      if (event.target === dialog) dialog.close();
    });
  </script>
</Layout>
